# 統一所有文字檔使用 LF
* text=auto eol=lf

# Markdown 文件 (README, docs)
*.md text eol=lf

# Shell 腳本
*.sh text eol=lf

# YAML 設定檔 (GitHub Actions, CI/CD)
*.yml text eol=lf
*.yaml text eol=lf

# INI 設定檔 (systemd)
*.ini text eol=lf
*.service text eol=lf

# 環境變數檔
*.env text eol=lf

# Git 設定檔
.gitattributes text eol=lf
.gitignore text eol=lf
